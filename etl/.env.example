# Variables de entorno para el ETL de Transparencia Perú
# Copiar a .env y completar con valores reales
# NUNCA commitear el archivo .env al repositorio

# --- Supabase ---
SUPABASE_URL=https://<tu-proyecto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role_key_del_dashboard>

# --- ETL ---
# Token secreto compartido entre la Edge Function y el microservicio Python
ETL_SHARED_SECRET=<token-secreto-largo-y-aleatorio>

# URL donde corre el microservicio Python (Railway, Render, Cloud Run, etc.)
# Dejar vacío si corres el ETL localmente o vía cron de GitHub Actions
ETL_RUNNER_URL=https://<tu-microservicio>.up.railway.app
